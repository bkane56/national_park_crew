# Canonical local env file location:
#   national_park_crew/.env
# Copy this file to that path before running `uv run run_ui`.
#
# SECURITY:
# - Never commit a real `.env` file.
# - Use unique secrets per environment.
OPENAI_API_KEY=your_openai_api_key_here

# Keep deployments demo-first by default.
# A valid REAL_RUN_ACCESS_CODE entered in the UI still authorizes one real run.
REAL_RUNS_ENABLED=false
REAL_RUN_ACCESS_CODE=replace_with_private_access_code

# Optional: disable telemetry for local and hosted runs.
CREWAI_DISABLE_TELEMETRY=true
OTEL_SDK_DISABLED=true

# Optional runtime safety limit (seconds).
PLANNER_MAX_RUNTIME_SECONDS=600
