# Copy to .env and fill in. Used by CrewAI + OpenAI-backed agents (see agents.yaml).
OPENAI_API_KEY=******

# REAL_RUNS_ENABLED=false keeps the deployment demo-first by default.
# A valid REAL_RUN_ACCESS_CODE entered in the UI still authorizes one real run per request.
REAL_RUNS_ENABLED=false
REAL_RUN_ACCESS_CODE=replace-with-private-code

# Optional: disable telemetry for local and hosted runs.
CREWAI_DISABLE_TELEMETRY=true
OTEL_SDK_DISABLED=true
